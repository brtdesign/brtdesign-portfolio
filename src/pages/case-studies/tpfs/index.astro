---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="TPFS · Case Study">
  <section>
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/home">Home</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">TPFS</span>
    </nav>

    <h1 class="hero-title">TPFS<span class="flourish-period">.</span></h1>

    <ul class="meta-list meta-list--casestudy meta-list--pills">
      <li></li>
    </ul>

    <div class="hero-wrapper">
      <section class="hero-lead"></section>

      <section class="card card--role card--compact card--transparent">
        <h2>Role</h2>
        <ul class="role-list"></ul>
      </section>
    </div>

    <ul class="tools-list"></ul>

    <section class="card content-block">
      <h2>Problem</h2>
    </section>

    <section class="card content-block">
      <h2>Approach</h2>
    </section>

    <section class="card content-block">
      <h2>Build</h2>
    </section>

    <section class="card content-block">
      <h2>Testing</h2>
    </section>

    <section class="card content-block">
      <h2>Impact</h2>
    </section>
  </section>
</BaseLayout>
