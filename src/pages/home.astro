---
import BaseLayout from "../layouts/BaseLayout.astro";
import CaseGrid from "../components/CaseGrid.jsx";
import { Image } from "astro:assets";
import homeXwImage from "../images/xpress-weigh/home-xw.png";
import homeCadenceImage from "../images/cadence/home-cadence.png";
import homeOxfamImage from "../images/tag-your-bag/home.png";
import homeFutureStateImage from "../images/future-state/homepage.png";
---

<BaseLayout title="Ben Taylor · Experience Design Portfolio">
  <section class="page-intro">
    <h1 class="hero-title">
      <span class="hero-soft">Strategic thinking. Practical design.</span>
      Thoughtful design for complex problems
      <span class="flourish-ampersand">&amp;</span> fast-moving teams<span
        class="flourish-period">.</span
      >
    </h1>
    <p class="hero-lead">
      I’m a senior UX designer who thrives in ambiguity and helps teams bring
      clarity to complex problems. I work closely with stakeholders, engineers,
      and users to understand what really matters, and I design solutions that
      are practical, thoughtful, and scalable.
    </p>
    <div class="hero-cta-row">
      <a class="button primary inverted" href="/about">About me</a>
    </div>
  </section>

  <section class="selected-work">
    <div class="split">
      <div class="card">
        <h2>
          Redesigning a legacy member-support tool within a 50-year-old
          operating model.
        </h2>
        <ul class="meta-list meta-list--pills">
          <li>Slimming World</li>
          <li>2025</li>
        </ul>
        <div class="homepage-casestudy--image">
          <Image
            src={homeXwImage}
            alt="Xpress Weigh case study"
            style="height:auto; width:100%; display:block;"
            widths={[480, 768]}
            sizes="100vw"
          />
        </div>
        <p>
          A multi-phase transformation of a live group system used weekly by
          thousands of Consultants, supporting hundreds of thousands of members.
        </p>

        <a class="button primary" href="/case-studies/xpress-weigh"
          >View case study</a
        >
      </div>

      <div class="card">
        <h2>
          Building a context-aware strength training app from concept to Android
          Store release.
        </h2>
        <ul class="meta-list meta-list--pills">
          <li>Self-initiated</li>
          <li>2026</li>
        </ul>
        <div class="homepage-casestudy--image">
          <Image
            src={homeCadenceImage}
            alt="Cadence case study"
            style="height:auto; width:100%; display:block;"
            widths={[480, 768]}
            sizes="100vw"
          />
        </div>
        <p>
          A self-initiated product exploring AI-augmented development as a
          practical way to shorten the path from idea to working software.
        </p>

        <a class="button primary" href="/case-studies/cadence"
          >View case study</a
        >
      </div>
    </div>
    <div class="split">
      <div class="card">
        <h2>Driving Gift-aid revenue across Oxfam stores</h2>
        <ul class="meta-list meta-list--pills">
          <li>Oxfam <span style="text-transform:none">(via PXTech)</span></li>
          <!-- <li>2026</li> -->
        </ul>
        <div class="homepage-casestudy--image">
          <Image
            src={homeOxfamImage}
            alt="Cadence case study"
            style="height:auto; width:100%; display:block;"
            widths={[480, 768]}
            sizes="100vw"
          />
        </div>
        <p>
          Reducing invalid Gift Aid registrations by ~50%, protecting ~£500k in
          annual charity income.
        </p>

        <a class="button primary" href="/case-studies/tag-your-bag"
          >View case study</a
        >
      </div>
      <div class="card">
        <h2>
         Designing joined-up journeys across actors and touchpoints
        </h2>
        <ul class="meta-list meta-list--pills">
          <li>Slimming World</li>
          <li>2024</li>
        </ul>
        <div class="homepage-casestudy--image">
          <Image
            src={homeFutureStateImage}
            alt="Future state case study"
            style="height:auto; width:100%; display:block;"
            widths={[480, 768]}
            sizes="100vw"
          />
        </div>
        <p>
          Bringing clarity and alignment to loosely defined transformation ambition.
        </p>
        <a href="/case-studies/future-state" class="button primary">
          View case study
        </a>
      </div>
    </div>
  </section>

  <style>
    .hero-cta-row {
      margin-top: var(--space-3);
      padding-left: var(--space-1);
    }
  </style>
</BaseLayout>
